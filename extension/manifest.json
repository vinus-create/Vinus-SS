{
  "manifest_version": 3,
  "name": "ShopeeScope",
  "version": "1.0.0",
  "description": "Shopee competitor intelligence — one-click daily scraper & live progress",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "tabs"],
  "host_permissions": [
    "https://shopee.com.my/*",
    "https://vinus-ss.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ShopeeScope",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://shopee.com.my/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["run-daily.js", "scrape-single.js"],
      "matches": ["https://shopee.com.my/*"]
    }
  ]
}
